{
  "manifest_version": 3,
  "name": "LinkedIn Job Classifier",
  "version": "3.0",
  "description": "AI-powered job classifier for LinkedIn job search.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.openai.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["https://www.linkedin.com/jobs/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_title": "LinkedIn Job Classifier",
    "default_popup": "popup.html"
  },
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "icons": {
    "16": "icons/icon-default-16.png",
    "48": "icons/icon-default-48.png",
    "128": "icons/icon-default-128.png"
  }
}
